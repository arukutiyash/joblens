{
  "manifest_version": 3,
  "name": "JobLens — AI Job Assistant",
  "version": "1.0.0",
  "description": "AI-powered job assistant. ATS match score, JD summary, skill gaps, cover letter, and people finder — all in one sidebar.",

  "permissions": [
    "storage",
    "activeTab"
  ],

  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://indeed.com/*",
    "https://www.indeed.com/*",
    "https://api.openai.com/*"
  ],

  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "src/background/background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://indeed.com/viewjob*",
        "https://www.indeed.com/viewjob*"
      ],
      "js": ["src/content/content.js"],
      "css": ["src/content/sidebar.css"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
